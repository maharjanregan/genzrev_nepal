---
const today = new Date();
---

<footer>
	<div class="inner">
		<div class="muted">
			&copy; {today.getFullYear()} Gen Z Movement in Nepal: Technology Impact Review.
		</div>
		<div class="muted">
			Source code: <a href="https://github.com/maharjanregan/genzrev_nepal">github.com/maharjanregan/genzrev_nepal</a>
		</div>
	</div>
</footer>

<style>
	footer {
		padding: 3rem 1rem 4rem;
		border-top: 1px solid rgba(var(--black), 10%);
		color: rgba(var(--black), 65%);
		background: #fff;
	}
	.inner {
		max-width: 1120px;
		margin: 0 auto;
		display: grid;
		gap: 0.35rem;
	}
	.muted {
		font-size: 0.95rem;
	}
	a {
		color: inherit;
	}
	a:hover {
		color: rgba(var(--black), 90%);
	}
</style>
