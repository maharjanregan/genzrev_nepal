---
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import HeaderLink from './HeaderLink.astro';

const base = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: import.meta.env.BASE_URL + '/';
---

<header class="topbar">
	<nav class="nav" aria-label="Site">
		<div class="brand">
			<button
				id="docs-menu-btn"
				class="menu"
				type="button"
				aria-label="Open navigation"
				aria-controls="docs-sidebar"
				aria-expanded="false"
			>
				☰
			</button>
			<a class="brand__title" href={base}>{SITE_TITLE}</a>
			<p class="brand__tagline">{SITE_DESCRIPTION}</p>
		</div>
		<div class="links" aria-label="Primary navigation">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/executive-brief">Brief</HeaderLink>
			<HeaderLink href="/method">Method</HeaderLink>
			<HeaderLink href="/timeline">Timeline</HeaderLink>
			<HeaderLink href="/claims">Claims</HeaderLink>
			<HeaderLink href="/bibliography">Sources</HeaderLink>
		</div>
	</nav>
</header>

<style>
	.topbar {
		position: sticky;
		top: 0;
		z-index: 20;
		border-bottom: 1px solid rgba(var(--black), 10%);
		background: rgba(255, 255, 255, 0.86);
		backdrop-filter: blur(10px);
	}
	.nav {
		max-width: 1120px;
		margin: 0 auto;
		padding: 0.95rem 1.25rem;
		display: flex;
		gap: 1rem;
		align-items: flex-start;
		justify-content: space-between;
	}
	.brand {
		min-width: 260px;
	}
	.brand__title {
		font-weight: 700;
		letter-spacing: -0.02em;
		text-decoration: none;
		color: rgb(var(--black));
	}
	.brand__tagline {
		margin: 0.25rem 0 0;
		font-size: 0.85rem;
		color: rgba(var(--black), 70%);
		max-width: 60ch;
	}
	.menu {
		display: none;
		border: 1px solid rgba(var(--black), 15%);
		background: rgba(255, 255, 255, 0.7);
		border-radius: 10px;
		padding: 0.35rem 0.55rem;
		line-height: 1;
		font-size: 1rem;
		cursor: pointer;
		margin-right: 0.5rem;
	}
	.menu:hover {
		background: rgba(255, 255, 255, 1);
	}
	.links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.6rem 1rem;
		align-items: center;
		justify-content: flex-end;
		padding-top: 0.15rem;
	}

	@media (max-width: 920px) {
		.brand__tagline {
			display: none;
		}
		.nav {
			align-items: center;
		}
		.menu {
			display: inline-flex;
		}
	}
</style>
