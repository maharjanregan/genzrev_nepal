---
// Minimal TOC: finds headings in the rendered HTML.
// Works for MD/MDX and Astro pages when passed `html`.
const { html } = Astro.props as { html: string };

function slugify(s: string) {
	return s
		.toLowerCase()
		.trim()
		.replace(/[^a-z0-9\s-]/g, '')
		.replace(/\s+/g, '-')
		.replace(/-+/g, '-');
}

const headings = Array.from(html.matchAll(/<h([23])([^>]*)>(.*?)<\/h\1>/g)).map((m) => {
	const level = Number(m[1]);
	const attrs = m[2] ?? '';
	const text = (m[3] ?? '').replace(/<[^>]+>/g, '').trim();
	const idMatch = attrs.match(/id=\"([^\"]+)\"/);
	const id = idMatch?.[1] ?? slugify(text);
	return { level, text, id };
});
---

{headings.length > 0 ? (
	<aside class="toc" aria-label="On this page">
		<div class="toc__title">On this page</div>
		<nav class="toc__nav">
			{headings.map((h) => (
				<a class:list={['toc__item', h.level === 3 && 'toc__item--h3']} href={`#${h.id}`}
					>{h.text}</a
				>
			))}
		</nav>
	</aside>
) : null}

<style>
	.toc {
		position: sticky;
		top: 84px;
		padding: 1.25rem 0.75rem;
		border-left: 1px solid rgba(var(--black), 10%);
		max-height: calc(100dvh - 84px);
		overflow: auto;
	}
	.toc__title {
		font-size: 0.85rem;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: rgba(var(--black), 60%);
		margin: 0.25rem 0 0.75rem;
	}
	.toc__nav {
		display: grid;
		gap: 0.3rem;
	}
	.toc__item {
		color: rgba(var(--black), 75%);
		text-decoration: none;
		font-size: 0.95rem;
		line-height: 1.35;
	}
	.toc__item:hover {
		color: rgba(var(--black), 90%);
	}
	.toc__item--h3 {
		padding-left: 0.75rem;
		font-size: 0.9rem;
	}
</style>
